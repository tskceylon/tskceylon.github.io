---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProductCard from '../components/ProductCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { products } from '../data/products';
import { services } from '../data/services';
---
<BaseLayout title="Home" path="">
  <Hero />
  <TrustStrip />
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading eyebrow="Products" title="Extinguishers for every risk"
      intro="The right extinguisher depends on what could catch fire. Here are the types we supply." />
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {products.slice(0, 3).map((product) => <ProductCard product={product} />)}
    </div>
    <a href="/products" class="inline-block mt-6 font-bold text-action-dark border-b-2 border-action-dark">See all products →</a>
  </section>
  <section class="bg-surface-alt border-y border-line">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeading eyebrow="Services" title="More than just sales"
        intro="We keep your extinguishers ready and your premises compliant year-round." />
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading eyebrow="Why TSK Ceylon" title="Safety partners, not just suppliers" />
    <div class="mt-10 grid gap-10 md:gap-8 md:grid-cols-3">
      <div>
        <div class="flex h-10 w-10 items-center justify-center rounded-md bg-action-dark/10 text-action-dark">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-extrabold text-navy">Certified products</h3>
        <p class="mt-2 text-sm text-muted leading-relaxed">Extinguishers meeting recognised standards.</p>
      </div>
      <div>
        <div class="flex h-10 w-10 items-center justify-center rounded-md bg-action-dark/10 text-action-dark">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-extrabold text-navy">End-to-end service</h3>
        <p class="mt-2 text-sm text-muted leading-relaxed">Supply, install, refill, inspect — one partner.</p>
      </div>
      <div>
        <div class="flex h-10 w-10 items-center justify-center rounded-md bg-action-dark/10 text-action-dark">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-extrabold text-navy">Responsive</h3>
        <p class="mt-2 text-sm text-muted leading-relaxed">Fast quotes by phone, WhatsApp or the form.</p>
      </div>
    </div>
  </section>
</BaseLayout>
