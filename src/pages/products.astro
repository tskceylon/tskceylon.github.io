---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products';
---
<BaseLayout title="Products" path="products"
  description="Dry powder, CO₂, foam, water and wet chemical fire extinguishers supplied across Sri Lanka by TSK Ceylon.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading eyebrow="Products" title="Our fire extinguisher range"
      intro="Not sure which you need? Send us your premises details and we’ll recommend the right mix." />
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>
