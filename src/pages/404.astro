---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" path="404">
  <section class="mx-auto max-w-6xl px-4 py-28 text-center">
    <p class="text-sm font-bold tracking-[0.2em] text-action-dark uppercase">404</p>
    <h1 class="mt-3 text-4xl font-extrabold">Page not found</h1>
    <p class="mt-4 text-muted">The page you’re looking for doesn’t exist.</p>
    <a href="/" class="inline-block mt-8 rounded-md bg-action px-6 py-3 font-bold text-white hover:bg-action-dark transition-colors">Back to home</a>
  </section>
</BaseLayout>
