---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';
import { facilityImage } from '../data/images';
---
<BaseLayout title="About" path="about"
  description="TSK Ceylon — trusted fire extinguisher supplier and servicing partner in Sri Lanka.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeading eyebrow="About" title={`About ${site.name}`} />
    <div class="mt-8 overflow-hidden rounded-2xl border border-line shadow-card">
      <Image
        src={facilityImage}
        alt="Rows of red fire extinguishers in the TSK Ceylon inspection bay"
        widths={[800, 1200, 1600]}
        sizes="(max-width: 1024px) 100vw, 1024px"
        loading="lazy"
        class="aspect-[16/9] w-full object-cover"
      />
    </div>
    <div class="mx-auto mt-10 max-w-3xl space-y-4 text-muted leading-relaxed">
      <p>{site.name} supplies, installs and services certified fire extinguishers for
        businesses and homes across Sri Lanka. From a single extinguisher to fitting out
        a full facility, we help you meet fire-safety requirements with the right
        equipment and dependable after-sales service.</p>
      <p>We work with offices, factories, hotels, restaurants, schools and hospitals —
        advising on the correct extinguisher type for each area, then keeping them
        serviced and compliant year after year.</p>
    </div>
    <div class="mx-auto mt-10 max-w-3xl rounded-xl border border-line bg-surface p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4 shadow-card">
      <div>
        <h2 class="text-xl font-extrabold text-navy">Download our company profile</h2>
        <p class="mt-1 text-sm text-muted">An 11-page PDF — our story, products, services, and contact details.</p>
      </div>
      <a href="/company-profile.pdf" download
         class="inline-flex items-center justify-center gap-2 rounded-md bg-action px-6 py-3 font-bold text-white hover:bg-action-dark transition-colors whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Download PDF
      </a>
    </div>
  </section>
</BaseLayout>
