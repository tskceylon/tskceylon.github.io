---
import { site } from '../data/site';
const path = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/';
---
<header class="border-b border-line bg-surface sticky top-0 z-40">
  <div class="mx-auto max-w-6xl px-4 h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-extrabold text-navy text-lg tracking-tight">
      <img src="/favicon.svg" alt="" width="28" height="28" />
      {site.name}
    </a>
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6 text-sm font-semibold">
      {site.nav.map((item) => (
        <a
          href={item.href}
          aria-current={path === item.href ? 'page' : undefined}
          class:list={[
            'hover:text-action-dark transition-colors',
            path === item.href ? 'text-action-dark' : 'text-ink',
          ]}
        >{item.label}</a>
      ))}
    </nav>
    <a
      href={`tel:${site.phoneHref}`}
      class="inline-flex items-center gap-2 rounded-md bg-action px-4 py-2 text-sm font-bold text-white hover:bg-action-dark transition-colors"
    >
      <span aria-hidden="true">📞</span><span class="hidden sm:inline">{site.phoneDisplay}</span>
      <span class="sm:hidden">Call</span>
    </a>
  </div>
</header>
