---
import { site } from '../data/site';
---
<section class="bg-navy">
  <div class="container-wrap py-section-sm md:py-section flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <div>
      <h2 class="text-2xl font-extrabold text-white">Need extinguishers for your premises?</h2>
      <p class="mt-2 text-slate-300">Tell us your requirement — we’ll respond with a quote fast.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="rounded-md bg-action px-6 py-3 font-bold text-white hover:bg-action-dark transition-colors">Get a Quote</a>
      <a href={`tel:${site.phoneHref}`} class="rounded-md border border-white/30 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">{site.phoneDisplay}</a>
    </div>
  </div>
</section>
