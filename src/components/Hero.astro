---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import { heroImage } from '../data/images';
const waHref = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---
<section class="border-b border-line">
  <div class="container-wrap py-hero-sm md:py-hero">
    <div class="grid items-center gap-10 md:grid-cols-[1.05fr_1fr] md:gap-14">
      <div>
        <p class="flex items-center gap-3 text-sm font-bold tracking-[0.2em] text-action-dark uppercase">
          <span class="h-[2px] w-8 bg-action-dark" aria-hidden="true"></span>
          Certified Fire Safety · Sri Lanka
        </p>
        <h1 class="mt-5 text-4xl md:text-5xl font-extrabold leading-tight">
          Fire extinguishers & servicing you can trust
        </h1>
        <p class="mt-5 text-lg text-muted">
          TSK Ceylon supplies, installs and services certified extinguishers for offices,
          factories, hotels and homes — keeping your premises safe and compliant.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-md bg-action px-6 py-3 font-bold text-white hover:bg-action-dark transition-colors">Get a Quote</a>
          <a href={waHref} target="_blank" rel="noopener" class="rounded-md border border-line bg-white px-6 py-3 font-semibold text-ink hover:border-action transition-colors">WhatsApp Us</a>
          <a href="/company-profile.pdf" download class="rounded-md border border-line bg-white px-6 py-3 font-semibold text-ink hover:border-action transition-colors">Company Profile (PDF)</a>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-4 -z-10 rounded-3xl bg-action/5" aria-hidden="true"></div>
        <div class="absolute -bottom-6 -right-6 -z-10 hidden h-32 w-32 rounded-full bg-action/10 md:block" aria-hidden="true"></div>
        <Image
          src={heroImage}
          alt="Wall-mounted red fire extinguisher beside a green exit sign in a modern office corridor"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="eager"
          fetchpriority="high"
          class="relative w-full rounded-2xl shadow-card"
        />
      </div>
    </div>
  </div>
</section>
