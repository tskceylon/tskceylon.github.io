---
interface Props { eyebrow?: string; title: string; intro?: string; }
const { eyebrow, title, intro } = Astro.props;
---
<div class="max-w-2xl">
  {eyebrow && <p class="text-xs font-bold tracking-[0.2em] text-action-dark uppercase">{eyebrow}</p>}
  <h2 class="mt-2 text-3xl font-extrabold">{title}</h2>
  {intro && <p class="mt-3 text-muted">{intro}</p>}
</div>
