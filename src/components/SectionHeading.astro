---
interface Props { eyebrow?: string; title: string; intro?: string; as?: 'h1' | 'h2'; }
const { eyebrow, title, intro, as: Tag = 'h2' }: Props = Astro.props;
---
<div class="max-w-2xl">
  {eyebrow && (
    <p class="flex items-center gap-3 text-xs font-bold tracking-[0.2em] text-action-dark uppercase">
      <span class="h-[2px] w-8 bg-action-dark" aria-hidden="true"></span>
      {eyebrow}
    </p>
  )}
  <Tag class="mt-3 text-3xl font-extrabold">{title}</Tag>
  {intro && <p class="mt-4 text-muted">{intro}</p>}
</div>
