---
import { site } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="bg-navy-soft text-slate-300">
  <div class="container-wrap py-section-sm md:py-section grid gap-10 md:grid-cols-3">
    <div>
      <span class="inline-flex bg-white rounded-lg p-3">
        <img src="/logo.png" alt={site.name} width="81" height="80" class="h-20 w-auto" />
      </span>
      <p class="mt-3 text-sm leading-relaxed">{site.tagline}</p>
    </div>
    <div class="text-sm leading-relaxed">
      <p class="text-white font-semibold mb-2">Contact</p>
      <p>{site.address.street}, {site.address.city}</p>
      <p>{site.address.region} {site.address.postalCode}, {site.address.country}</p>
      <p class="mt-2"><a class="hover:text-white" href={`tel:${site.phoneHref}`}>{site.phoneDisplay}</a></p>
      <p><a class="hover:text-white" href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
    <div class="text-sm leading-relaxed">
      <p class="text-white font-semibold mb-2">Hours</p>
      {site.hours.map((h) => <p>{h.days}: {h.hours}</p>)}
      <p class="text-white font-semibold mt-5 mb-2">Quick Links</p>
      <nav aria-label="Footer" class="flex flex-wrap gap-x-4 gap-y-1">
        {site.nav.map((item) => <a class="hover:text-white" href={item.href}>{item.label}</a>)}
        <a class="hover:text-white" href="/company-profile.pdf" download>Company Profile (PDF)</a>
      </nav>
    </div>
  </div>
  <div class="border-t border-white/10">
    <p class="container-wrap py-5 text-xs text-slate-400">
      © {year} {site.legalName}. All rights reserved.
    </p>
  </div>
</footer>
