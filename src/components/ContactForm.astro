---
import { site } from '../data/site';
---
<form id="contact-form" class="grid gap-4 max-w-xl" novalidate>
  <input type="hidden" name="access_key" value={site.web3formsAccessKey} />
  <input type="hidden" name="subject" value="New inquiry from TSK Ceylon website" />
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="grid gap-1">
    <label for="cf-name" class="text-sm font-semibold">Name</label>
    <input
      id="cf-name"
      name="name"
      type="text"
      autocomplete="name"
      placeholder="Your full name"
      maxlength="80"
      required
      class="rounded-md border border-line px-3 py-2.5"
    />
  </div>
  <div class="grid gap-1">
    <label for="cf-phone" class="text-sm font-semibold">Phone / WhatsApp</label>
    <input
      id="cf-phone"
      name="phone"
      type="tel"
      inputmode="tel"
      autocomplete="tel"
      spellcheck="false"
      placeholder="077 123 4567"
      maxlength="30"
      required
      class="rounded-md border border-line px-3 py-2.5"
    />
  </div>
  <div class="grid gap-1">
    <label for="cf-email" class="text-sm font-semibold">Email <span class="text-muted font-normal">(optional)</span></label>
    <input
      id="cf-email"
      name="email"
      type="email"
      inputmode="email"
      autocomplete="email"
      spellcheck="false"
      placeholder="you@example.com"
      maxlength="120"
      class="rounded-md border border-line px-3 py-2.5"
    />
  </div>
  <div class="grid gap-1">
    <label for="cf-msg" class="text-sm font-semibold">What do you need?</label>
    <textarea
      id="cf-msg"
      name="message"
      rows="4"
      maxlength="1500"
      placeholder="Tell us about your premises and how many extinguishers you need…"
      required
      class="rounded-md border border-line px-3 py-2.5"
    ></textarea>
  </div>

  <button id="cf-submit" type="submit" class="rounded-md bg-action px-6 py-3 min-h-[44px] font-bold text-white hover:bg-action-dark transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
    Send Inquiry
  </button>
  <p id="cf-status" role="status" aria-live="polite" class="text-sm"></p>
</form>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('cf-status');
    const submit = document.getElementById('cf-submit') as HTMLButtonElement | null;
    if (!form || !status || !submit) return;
    if ((form as any).__bound) return;
    (form as any).__bound = true;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        const firstInvalid = form.querySelector(':invalid:not([type="hidden"])') as HTMLElement | null;
        firstInvalid?.focus();
        status.textContent = 'Please fill in the required fields.';
        status.className = 'text-sm font-semibold text-action-dark';
        return;
      }
      submit.disabled = true;
      const originalLabel = submit.textContent;
      submit.textContent = 'Sending…';
      status.textContent = 'Sending…';
      status.className = 'text-sm text-muted';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          status.textContent = 'Thank you — we’ll be in touch shortly.';
          status.className = 'text-sm font-semibold text-green-700';
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch {
        status.textContent =
          'Sorry, something went wrong. Please call or WhatsApp us instead.';
        status.className = 'text-sm font-semibold text-action-dark';
      } finally {
        submit.disabled = false;
        submit.textContent = originalLabel;
      }
    });
  }

  document.addEventListener('astro:page-load', initContactForm);
</script>
