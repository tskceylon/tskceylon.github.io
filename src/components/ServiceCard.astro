---
import { Image } from 'astro:assets';
import type { Service } from '../data/types';
import { serviceImages } from '../data/images';
interface Props { service: Service; }
const { service } = Astro.props;
const img = serviceImages[service.slug];
---
<article class="flex flex-col overflow-hidden rounded-lg border border-line bg-surface shadow-card hover:border-action hover:shadow-card-hover transition-all duration-200">
  {img && (
    <div class="aspect-[3/2] overflow-hidden bg-surface-alt">
      <Image
        src={img}
        alt={`Illustration: ${service.name}`}
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 50vw"
        loading="lazy"
        class="h-full w-full object-cover"
      />
    </div>
  )}
  <div class="flex flex-col p-6">
    <h3 class="text-lg font-extrabold text-navy">{service.name}</h3>
    <p class="mt-2 text-sm text-muted">{service.description}</p>
    <ul class="mt-4 space-y-1 text-sm text-muted">
      {service.points.map((p) => <li class="flex gap-2"><span class="text-action-dark" aria-hidden="true">✓</span>{p}</li>)}
    </ul>
  </div>
</article>
